APP_ENV=production
DJANGO_DEBUG=0
LOG_LEVEL=INFO
PYTHON_VERSION=3.11.9

DJANGO_BASE_URL=https://databridge-web.onrender.com
FASTAPI_BASE_URL=https://databridge-api.onrender.com
PUBLIC_API_BASE_URL=https://databridge-api.onrender.com

DJANGO_SECRET_KEY=replace-with-a-long-random-django-secret
DJANGO_ALLOWED_HOSTS=databridge-web.onrender.com
DJANGO_CSRF_TRUSTED_ORIGINS=https://databridge-web.onrender.com
CORS_ALLOWED_ORIGINS=https://databridge-web.onrender.com

# Django auth/session database. Use a persistent Render Disk path if Django stays on SQLite.
DJANGO_DB_PATH=/var/data/django_ui.sqlite3

DATABRIDGE_DB_BACKEND=turso
DATABRIDGE_DB_PATH=
TURSO_DATABASE_URL=replace-with-your-turso-database-url
TURSO_AUTH_TOKEN=replace-with-your-turso-read-write-token

# Protects Django -> FastAPI calls. Never put this token in a public URL.
INTERNAL_API_TOKEN=replace-with-a-long-random-internal-token

# Protects generated CSV/JSON export URLs through slug-scoped signed tokens.
# This is a Richat DataBridge secret, not an OpenDataSoft API key.
DATABRIDGE_EXPORT_TOKEN=replace-with-a-long-random-export-token

REMOTE_PROVIDER=opendatasoft_url
PUBLISH_MODE=opendatasoft_url
ODS_API_KEY=

AI_PROVIDER=gemini
SUPPORTED_AI_PROVIDERS=gemini,openai,azure_openai,anthropic,mistral,deepseek,cohere,groq,together,xai,perplexity
AI_OUTPUT_TYPE=dictionary
AI_RESPONSE_MODE=json_schema
AI_TEMPERATURE=0
AI_MODEL=gemini-2.5-flash-lite
AI_MAX_CANDIDATES=40
AI_TARGET_INDICATORS=5
AI_ENABLE_BUSINESS_RULES=1
AI_LOG_DECISIONS=1
WB_MAX_INDICATORS_PER_DATASET=60

GEMINI_API_KEY=replace-with-your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=2024-12-01-preview
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-latest
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-small-latest
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
COHERE_API_KEY=
COHERE_MODEL=command-r-plus
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-70b-versatile
TOGETHER_API_KEY=
TOGETHER_MODEL=meta-llama/Llama-3.1-70B-Instruct-Turbo
XAI_API_KEY=
XAI_MODEL=grok-2-latest
PERPLEXITY_API_KEY=
PERPLEXITY_MODEL=sonar
