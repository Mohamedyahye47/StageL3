APP_ENV=production
DJANGO_DEBUG=0
LOG_LEVEL=INFO
PYTHON_VERSION=3.11.9

DJANGO_BASE_URL=https://databridge.onrender.com
PUBLIC_API_BASE_URL=https://databridge.onrender.com

DJANGO_SECRET_KEY=replace-with-a-long-random-django-secret
DJANGO_ALLOWED_HOSTS=databridge.onrender.com
DJANGO_CSRF_TRUSTED_ORIGINS=https://databridge.onrender.com
CORS_ALLOWED_ORIGINS=https://databridge.onrender.com

DATABRIDGE_DB_BACKEND=turso
TURSO_DATABASE_URL=replace-with-your-main-turso-database-url
TURSO_AUTH_TOKEN=replace-with-your-main-turso-read-write-token

DJANGO_TURSO_DATABASE_URL=replace-with-your-django-turso-database-url
DJANGO_TURSO_AUTH_TOKEN=replace-with-your-django-turso-read-write-token

INTERNAL_API_TOKEN=replace-with-a-long-random-internal-token
DATABRIDGE_EXPORT_TOKEN=replace-with-a-long-random-export-token

REMOTE_PROVIDER=opendatasoft_url
PUBLISH_MODE=opendatasoft_url
ODS_PUBLISH_MODE=manual_url
ODS_DOMAIN=https://richat.opendatasoft.com
ODS_DEFAULT_THEME=Economie, finances, affaires, finances publiques
ODS_DEFAULT_LICENSE=
ODS_PRODUCER=Richat DataBridge
ODS_ORGANIZATION=Richat Data Hub

# IA
# Provider actif. Valeurs possibles :
# local, gemini, openai, deepseek, mistral, groq, together, xai,
# perplexity, openrouter, fireworks, cerebras, nvidia, sambanova,
# openai_compatible
AI_PROVIDER=local
AI_MODEL=regles_metier_locales

# Clefs optionnelles. Vous pouvez en configurer plusieurs en meme temps.
# La page Configuration IA affichera uniquement les providers dont la clef est presente.
GEMINI_API_KEY=
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
MISTRAL_API_KEY=
GROQ_API_KEY=
TOGETHER_API_KEY=
XAI_API_KEY=
PERPLEXITY_API_KEY=
OPENROUTER_API_KEY=
FIREWORKS_API_KEY=
CEREBRAS_API_KEY=
NVIDIA_API_KEY=
SAMBANOVA_API_KEY=

# Provider personnalise compatible OpenAI Chat Completions.
# Utilisez ce bloc seulement pour un fournisseur non liste ci-dessus.
AI_BASE_URL=
AI_API_KEY=

# Extensions optionnelles des listes de modeles backend.
# Exemple : DEEPSEEK_MODELS=deepseek-new-model,deepseek-other-model
GEMINI_MODELS=
OPENAI_MODELS=
DEEPSEEK_MODELS=
MISTRAL_MODELS=
GROQ_MODELS=
TOGETHER_MODELS=
XAI_MODELS=
PERPLEXITY_MODELS=
OPENROUTER_MODELS=
FIREWORKS_MODELS=
CEREBRAS_MODELS=
NVIDIA_MODELS=
SAMBANOVA_MODELS=

AI_TEMPERATURE=0
AI_TIMEOUT_SECONDS=60
AI_MAX_CANDIDATES=40
AI_TARGET_INDICATORS=5
AI_ENABLE_BUSINESS_RULES=1
AI_LOG_DECISIONS=1
WB_MAX_INDICATORS_PER_DATASET=60

DATABRIDGE_SEED_METADATA_ON_STARTUP=0
